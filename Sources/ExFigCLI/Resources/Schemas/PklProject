amends "pkl:Project"

package {
  name = "exfig"
  baseUri = "package://pkg.pkl-lang.org/github.com/DesignPipe/exfig/exfig"
  version = "2.8.0"
  packageZipUrl = "https://github.com/DesignPipe/exfig/releases/download/v\(version)/\(name)@\(version).zip"
  description = "ExFig configuration schemas for exporting Figma assets to iOS, Android, Flutter, and Web"
  authors {
    "Alexey <akakoulin.dev@gmail.com>"
  }
  sourceCode = "https://github.com/DesignPipe/exfig"
  sourceCodeUrlScheme = "https://github.com/DesignPipe/exfig/blob/v\(version)/Sources/ExFigCLI/Resources/Schemas%{path}#L%{line}-L%{endLine}"
  license = "MIT"
}

dependencies {
  ["pkl.swift"] {
    uri = "package://pkg.pkl-lang.org/pkl-swift/pkl.swift@0.8.0"
  }
}
